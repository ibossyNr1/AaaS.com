rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Knowledge Index entity collections — public read, no public write
    match /tools/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /models/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /agents/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /skills/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /scripts/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /benchmarks/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Submissions — public write (API intake), no public read
    match /submissions/{document=**} {
      allow read: if false;
      allow write: if true;
    }

    // Registered agents — public read (profiles), no public write
    match /registered_agents/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Episodes — public read (podcast/content), no public write
    match /episodes/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Subscribers — public write (email signup), no public read
    match /subscribers/{document=**} {
      allow read: if false;
      allow write: if true;
    }

    // Webhooks — no public access (managed via API with auth)
    match /webhooks/{document=**} {
      allow read, write: if false;
    }

    // Webhook queue — internal only
    match /webhook_queue/{document=**} {
      allow read, write: if false;
    }

    // Entity snapshots — internal only (changelog agent)
    match /entity_snapshots/{document=**} {
      allow read, write: if false;
    }

    // Categorization suggestions — internal only
    match /categorization_suggestions/{document=**} {
      allow read, write: if false;
    }

    // Email logs — internal only
    match /email_logs/{document=**} {
      allow read, write: if false;
    }

    // Agent logs — public read (dashboard), no public write
    match /agent_logs/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Healing queue — internal only
    match /healing_queue/{document=**} {
      allow read, write: if false;
    }

    // Page views — public write (client tracking), no public read
    match /page_views/{document=**} {
      allow read: if false;
      allow write: if true;
    }

    // Page view counts — internal only
    match /page_view_counts/{document=**} {
      allow read, write: if false;
    }

    // Trending alerts — public read (dashboard), no public write
    match /trending_alerts/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Entity similarities — public read (entity pages), no public write
    match /entity_similarities/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Comments — public read and write (community discussions)
    match /comments/{document=**} {
      allow read: if true;
      allow write: if true;
    }

    // Entity metadata — public read (link previews), no public write
    match /entity_metadata/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Entity summaries — public read (entity pages), no public write
    match /entity_summaries/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Digests — public read (weekly digests), no public write
    match /digests/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Comparisons — public read (auto comparisons), no public write
    match /comparisons/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Users — authenticated read/write own profile
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // User behavior — authenticated read/write own data
    match /user_behavior/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Search logs — internal only (written by API)
    match /search_logs/{document=**} {
      allow read, write: if false;
    }

    // Search analytics — public read (dashboard), no public write
    match /search_analytics/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // API keys — no public access (managed via admin API)
    match /api_keys/{document=**} {
      allow read, write: if false;
    }

    // Rate limit anonymous — internal only (rate-limit middleware)
    match /rate_limit_anonymous/{document=**} {
      allow read, write: if false;
    }

    // Audio episodes — public read, no public write
    match /audio_episodes/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Video queue — no public access (managed via API)
    match /video_queue/{document=**} {
      allow read, write: if false;
    }

    // Health checks — public read (dashboard), no public write
    match /health_checks/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Health alerts — internal only (written by health agent)
    match /health_alerts/{document=**} {
      allow read, write: if false;
    }

    // Alert summaries — public read (dashboard), no public write
    match /alert_summaries/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Event log — public read (activity feed), no public write
    match /event_log/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Subscriptions — authenticated read/write own data
    match /subscriptions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Admin users — internal only
    match /admin_users/{document=**} {
      allow read, write: if false;
    }

    // System config — internal only
    match /system_config/{document=**} {
      allow read, write: if false;
    }

    // Agent triggers — internal only
    match /agent_triggers/{document=**} {
      allow read, write: if false;
    }

    // Entity clusters — public read (discovery), no public write
    match /entity_clusters/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Topic maps — public read (discovery), no public write
    match /topic_maps/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Discovery paths — public read (discovery), no public write
    match /discovery_paths/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // AI queries — authenticated write (internal), no read
    match /ai_queries/{document=**} {
      allow read: if false;
      allow write: if request.auth != null;
    }

    // Embedding sync — no client access (agent only)
    match /embedding_sync/{document=**} {
      allow read, write: if false;
    }

    // Discovery suggestions — authenticated read own doc only
    match /discovery_suggestions/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Anomalies — public read (dashboard), no public write
    match /anomalies/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Experiments — public read (experiment configs), no client write
    match /experiments/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Experiment events — authenticated write (tracking), no read
    match /experiment_events/{document=**} {
      allow read: if false;
      allow write: if request.auth != null;
    }

    // Experiment assignments — authenticated read/write own data
    match /experiment_assignments/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // System reports — public read (dashboard), no public write
    match /system_reports/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Pipeline metrics — public read (dashboard), no public write
    match /pipeline_metrics/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Workspaces — public read (public workspaces), authenticated write
    match /workspaces/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Workspace members — authenticated read (own workspaces), no public write (managed via API)
    match /workspace_members/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Workspace invites — authenticated read (own invites), no public write
    match /workspace_invites/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Workspace themes — public read, no client write (admin API)
    match /workspace_themes/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Entity collections — public read (public collections), authenticated write
    match /entity_collections/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Bookmarks — authenticated read/write own data
    match /bookmarks/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
